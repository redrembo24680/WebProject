# Database Configuration
DATABASE_URL=postgresql+psycopg://personal_note_user:personal_note_password@db:5432/personal_note_manager
POSTGRES_DB=personal_note_manager
POSTGRES_USER=personal_note_user
POSTGRES_PASSWORD=personal_note_password

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production

# Email Configuration (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=your-brevo-email@example.com
SMTP_PASSWORD=your-brevo-api-key

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
